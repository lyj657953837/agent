# ============================================================================
# Analysis Agent System - Environment Configuration Template
# ============================================================================
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env
#
# IMPORTANT: Never commit .env file to version control!
# ============================================================================

# ----------------------------------------------------------------------------
# Application Settings
# ----------------------------------------------------------------------------
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true

# ----------------------------------------------------------------------------
# File Storage Configuration
# ----------------------------------------------------------------------------
UPLOAD_DIR=./uploads
EXPORT_DIR=./exports
MAX_UPLOAD_SIZE_MB=500

# ----------------------------------------------------------------------------
# Authentication & Security
# ----------------------------------------------------------------------------
# IMPORTANT: Change this to a strong random key in production!
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
AUTH_SECRET_KEY=change-me-in-production

# ----------------------------------------------------------------------------
# LLM (VLLM) Configuration
# ----------------------------------------------------------------------------
# VLLM API endpoint (required for AI features)
VLLM_API_BASE=http://localhost:8080/v1

# API authentication key (if required by your VLLM server)
VLLM_API_KEY=EMPTY

# Model name to use for inference
MODEL_NAME=qwen3-vl-8b-instruct

# LLM generation parameters
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.7
LLM_TIMEOUT=120

# ----------------------------------------------------------------------------
# Database Configuration (MySQL)
# ----------------------------------------------------------------------------
# Database host address
DB_HOST=localhost

# Database port
DB_PORT=3306

# Database name
DB_NAME=analysis

# Database credentials (REQUIRED)
DB_USER=root
DB_PASSWORD=your-password-here

# Connection pool settings
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE=3600

# ----------------------------------------------------------------------------
# Notes:
# ----------------------------------------------------------------------------
# 1. All configuration values can be overridden by system environment variables
# 2. Empty values will use the fallback defaults defined in config.py
# 3. For production, always set strong passwords and secret keys
# 4. Test your configuration with: python test_config.py
# ============================================================================
